<UserControl x:Class="FirstFloor.ModernUI.App.Content.ControlsModernCommandBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mui="http://firstfloorsoftware.com/ModernUI"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="520">
    <Grid>
        <ScrollViewer>
            <StackPanel HorizontalAlignment="Left" Margin="0,0,32,0">

                <!-- ═══════════════════════════════════════════════════════ -->
                <!--  CommandBar                                            -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <TextBlock Text="COMMANDBAR" Style="{StaticResource Heading2}" Margin="0,0,0,8"/>
                <mui:BBCodeBlock Margin="0,0,0,20"
                    BBCode="Horizontal toolbar for screen-level actions. Each [b]CommandBarButton[/b] has an [b]Icon[/b] (any UIElement) and a [b]Label[/b]. Use [b]CommandBarSeparator[/b] to group related buttons. Set [b]IsCompact=&quot;True&quot;[/b] on the bar to show icons only."/>

                <!-- Warehouse operations bar -->
                <TextBlock Text="Warehouse operations" Foreground="{DynamicResource WindowTextReadOnly}" Margin="0,0,0,4"/>
                <mui:CommandBar HorizontalAlignment="Left" Margin="0,0,0,4">
                    <mui:CommandBarButton Label="Receive" Click="OnWarehouseButtonClick">
                        <mui:CommandBarButton.Icon>
                            <Path Data="M 7,1 L 7,11 M 3,7 L 7,11 L 11,7 M 1,13 L 13,13"
                                  Stroke="{DynamicResource ButtonText}" StrokeThickness="1.5"
                                  StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                                  Width="14" Height="14" Stretch="None"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </mui:CommandBarButton.Icon>
                    </mui:CommandBarButton>
                    <mui:CommandBarButton Label="Dispatch" Click="OnWarehouseButtonClick">
                        <mui:CommandBarButton.Icon>
                            <Path Data="M 1,7 L 11,7 M 7,3 L 11,7 L 7,11 M 13,1 L 13,13"
                                  Stroke="{DynamicResource ButtonText}" StrokeThickness="1.5"
                                  StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                                  Width="14" Height="14" Stretch="None"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </mui:CommandBarButton.Icon>
                    </mui:CommandBarButton>
                    <mui:CommandBarButton Label="Transfer" Click="OnWarehouseButtonClick">
                        <mui:CommandBarButton.Icon>
                            <Path Data="M 0,4 L 6,4 L 6,1 L 13,5.5 L 6,10 L 6,7 L 0,7 Z"
                                  Fill="{DynamicResource ButtonText}"
                                  Width="14" Height="11" Stretch="None"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </mui:CommandBarButton.Icon>
                    </mui:CommandBarButton>
                    <mui:CommandBarSeparator/>
                    <mui:CommandBarButton Label="Print" Click="OnWarehouseButtonClick">
                        <mui:CommandBarButton.Icon>
                            <Path Data="M 2,5 L 2,1 L 12,1 L 12,5 M 0,5 L 14,5 L 14,11 L 0,11 Z M 2,11 L 2,14 L 12,14 L 12,11 M 4,8 L 10,8"
                                  Stroke="{DynamicResource ButtonText}" StrokeThickness="1.2"
                                  StrokeLineJoin="Round" StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                                  Width="14" Height="14" Stretch="None"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </mui:CommandBarButton.Icon>
                    </mui:CommandBarButton>
                    <mui:CommandBarButton Label="Export" Click="OnWarehouseButtonClick">
                        <mui:CommandBarButton.Icon>
                            <Path Data="M 7,1 L 7,11 M 3,7 L 7,11 L 11,7"
                                  Stroke="{DynamicResource ButtonText}" StrokeThickness="1.5"
                                  StrokeEndLineCap="Round" StrokeStartLineCap="Round" StrokeLineJoin="Round"
                                  Width="14" Height="12" Stretch="None"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </mui:CommandBarButton.Icon>
                    </mui:CommandBarButton>
                    <mui:CommandBarSeparator/>
                    <mui:CommandBarButton Label="Refresh" Click="OnWarehouseButtonClick">
                        <mui:CommandBarButton.Icon>
                            <Path Data="M 12,5 A 5,5 0 1 0 9,11 M 9,11 L 12,11 L 12,14"
                                  Stroke="{DynamicResource ButtonText}" StrokeThickness="1.5"
                                  StrokeEndLineCap="Round" StrokeStartLineCap="Round" StrokeLineJoin="Round"
                                  Width="14" Height="14" Stretch="None"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </mui:CommandBarButton.Icon>
                    </mui:CommandBarButton>
                </mui:CommandBar>
                <TextBlock x:Name="WarehouseFeedback" Foreground="{DynamicResource Accent}" Margin="0,0,0,20"/>

                <!-- Order management bar -->
                <TextBlock Text="Order management" Foreground="{DynamicResource WindowTextReadOnly}" Margin="0,0,0,4"/>
                <mui:CommandBar HorizontalAlignment="Left" Margin="0,0,0,4">
                    <mui:CommandBarButton Label="New Order" Click="OnOrderButtonClick">
                        <mui:CommandBarButton.Icon>
                            <Path Data="M 7,1 L 7,13 M 1,7 L 13,7"
                                  Stroke="{DynamicResource ButtonText}" StrokeThickness="2"
                                  StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                                  Width="14" Height="14" Stretch="None"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </mui:CommandBarButton.Icon>
                    </mui:CommandBarButton>
                    <mui:CommandBarButton Label="Edit" Click="OnOrderButtonClick">
                        <mui:CommandBarButton.Icon>
                            <Path Data="M 1,12 L 1,9 L 9,1 L 12,4 L 4,12 Z M 9,1 L 12,4"
                                  Stroke="{DynamicResource ButtonText}" StrokeThickness="1.5"
                                  StrokeLineJoin="Round" StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                                  Width="14" Height="13" Stretch="None"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </mui:CommandBarButton.Icon>
                    </mui:CommandBarButton>
                    <mui:CommandBarButton Label="Cancel" Click="OnOrderButtonClick">
                        <mui:CommandBarButton.Icon>
                            <Path Data="M 2,2 L 12,12 M 12,2 L 2,12"
                                  Stroke="{DynamicResource ButtonText}" StrokeThickness="2"
                                  StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                                  Width="14" Height="14" Stretch="None"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </mui:CommandBarButton.Icon>
                    </mui:CommandBarButton>
                    <mui:CommandBarSeparator/>
                    <mui:CommandBarButton Label="Invoice" Click="OnOrderButtonClick">
                        <mui:CommandBarButton.Icon>
                            <Path Data="M 2,0 L 12,0 L 12,14 L 2,14 Z M 4,4 L 10,4 M 4,7 L 10,7 M 4,10 L 8,10"
                                  Stroke="{DynamicResource ButtonText}" StrokeThickness="1.2"
                                  StrokeLineJoin="Round" StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                                  Width="14" Height="14" Stretch="None"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </mui:CommandBarButton.Icon>
                    </mui:CommandBarButton>
                    <mui:CommandBarButton Label="Email" Click="OnOrderButtonClick">
                        <mui:CommandBarButton.Icon>
                            <Path Data="M 0,2 L 14,2 L 14,12 L 0,12 Z M 0,2 L 7,8 L 14,2"
                                  Stroke="{DynamicResource ButtonText}" StrokeThickness="1.2"
                                  StrokeLineJoin="Round" StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                                  Width="14" Height="14" Stretch="None"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </mui:CommandBarButton.Icon>
                    </mui:CommandBarButton>
                    <mui:CommandBarSeparator/>
                    <!-- Disabled button -->
                    <mui:CommandBarButton Label="Archive" IsEnabled="False">
                        <mui:CommandBarButton.Icon>
                            <Path Data="M 0,1 L 14,1 L 14,4 L 0,4 Z M 1,4 L 1,13 L 13,13 L 13,4 M 5,7 L 9,7"
                                  Stroke="{DynamicResource ButtonText}" StrokeThickness="1.2"
                                  StrokeLineJoin="Round" StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                                  Width="14" Height="14" Stretch="None"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </mui:CommandBarButton.Icon>
                    </mui:CommandBarButton>
                </mui:CommandBar>
                <TextBlock x:Name="OrderFeedback" Foreground="{DynamicResource Accent}" Margin="0,0,0,20"/>

                <!-- Compact mode (icons only) -->
                <TextBlock Text="Compact mode (IsCompact=&quot;True&quot;, labels hidden)" Foreground="{DynamicResource WindowTextReadOnly}" Margin="0,0,0,4"/>
                <mui:CommandBar IsCompact="True" HorizontalAlignment="Left" Margin="0,0,0,32">
                    <mui:CommandBarButton Label="Receive">
                        <mui:CommandBarButton.Icon>
                            <Path Data="M 7,1 L 7,11 M 3,7 L 7,11 L 11,7 M 1,13 L 13,13"
                                  Stroke="{DynamicResource ButtonText}" StrokeThickness="1.5"
                                  StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                                  Width="14" Height="14" Stretch="None"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </mui:CommandBarButton.Icon>
                    </mui:CommandBarButton>
                    <mui:CommandBarButton Label="Dispatch">
                        <mui:CommandBarButton.Icon>
                            <Path Data="M 1,7 L 11,7 M 7,3 L 11,7 L 7,11 M 13,1 L 13,13"
                                  Stroke="{DynamicResource ButtonText}" StrokeThickness="1.5"
                                  StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                                  Width="14" Height="14" Stretch="None"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </mui:CommandBarButton.Icon>
                    </mui:CommandBarButton>
                    <mui:CommandBarSeparator/>
                    <mui:CommandBarButton Label="Print">
                        <mui:CommandBarButton.Icon>
                            <Path Data="M 2,5 L 2,1 L 12,1 L 12,5 M 0,5 L 14,5 L 14,11 L 0,11 Z M 2,11 L 2,14 L 12,14 L 12,11 M 4,8 L 10,8"
                                  Stroke="{DynamicResource ButtonText}" StrokeThickness="1.2"
                                  StrokeLineJoin="Round" StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                                  Width="14" Height="14" Stretch="None"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </mui:CommandBarButton.Icon>
                    </mui:CommandBarButton>
                    <mui:CommandBarButton Label="Refresh">
                        <mui:CommandBarButton.Icon>
                            <Path Data="M 12,5 A 5,5 0 1 0 9,11 M 9,11 L 12,11 L 12,14"
                                  Stroke="{DynamicResource ButtonText}" StrokeThickness="1.5"
                                  StrokeEndLineCap="Round" StrokeStartLineCap="Round" StrokeLineJoin="Round"
                                  Width="14" Height="14" Stretch="None"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </mui:CommandBarButton.Icon>
                    </mui:CommandBarButton>
                </mui:CommandBar>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
