<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:FirstFloor.ModernUI.Windows.Controls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/FirstFloor.ModernUI;component/Assets/Converters.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ═══════════════════════════════════════════════════════════════════════
         InfoBar
         An inline notification bar with severity levels, a title, a message,
         and an optional dismiss button.

         Usage:
             <mui:InfoBar Severity="Warning"
                          Title="Low Stock"
                          Message="SKU-4821 has fallen below reorder threshold."
                          IsOpen="{Binding ShowStockAlert, Mode=TwoWay}"/>
    ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Internal dismiss button — intentionally not keyed for public use -->
    <Style x:Key="InfoBarCloseButtonStyle" TargetType="Button">
        <Setter Property="Focusable"       Value="False"/>
        <Setter Property="Width"           Value="24"/>
        <Setter Property="Height"          Value="24"/>
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground"      Value="{DynamicResource ButtonText}"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            SnapsToDevicePixels="True">
                        <Path Width="10" Height="10"
                              Stroke="{TemplateBinding Foreground}"
                              StrokeThickness="1.5"
                              StrokeEndLineCap="Round"
                              StrokeStartLineCap="Round"
                              Data="M 1,1 L 9,9 M 9,1 L 1,9"
                              Stretch="None"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ButtonBackgroundHover}"/>
                            <Setter Property="Foreground"                      Value="{DynamicResource ButtonTextHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ButtonBackgroundPressed}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="controls:InfoBar">
        <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
        <Setter Property="Foreground"        Value="{DynamicResource WindowText}"/>
        <Setter Property="Padding"           Value="12,10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:InfoBar">
                    <!-- Default = Information severity colours; triggers override for others -->
                    <Border x:Name="Chrome"
                            BorderThickness="3,0,0,0"
                            BorderBrush="#FF0078D4"
                            Background="#1A0078D4"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <DockPanel>
                            <!-- Dismiss button pinned to the right -->
                            <Button x:Name="PART_CloseButton"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource InfoBarCloseButtonStyle}"
                                    Margin="6,0,0,0"/>

                            <!-- Severity icon circle -->
                            <Border x:Name="IconBorder"
                                    DockPanel.Dock="Left"
                                    Width="20" Height="20"
                                    CornerRadius="10"
                                    Background="#FF0078D4"
                                    VerticalAlignment="Top"
                                    Margin="0,1,10,0">
                                <TextBlock x:Name="IconText"
                                           Text="i"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <!-- Title + message stack -->
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="TitleText"
                                           Text="{TemplateBinding Title}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource WindowText}"
                                           Margin="0,0,0,2"
                                           Visibility="{Binding Title, RelativeSource={RelativeSource TemplatedParent},
                                                        Converter={StaticResource NullOrEmptyStringToVisibilityConverter},
                                                        ConverterParameter=inverse}"/>
                                <TextBlock x:Name="MessageText"
                                           Text="{TemplateBinding Message}"
                                           Foreground="{DynamicResource WindowText}"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding Message, RelativeSource={RelativeSource TemplatedParent},
                                                        Converter={StaticResource NullOrEmptyStringToVisibilityConverter},
                                                        ConverterParameter=inverse}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsOpen" Value="False">
                            <Setter TargetName="Chrome" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="IsClosable" Value="False">
                            <Setter TargetName="PART_CloseButton" Property="Visibility" Value="Collapsed"/>
                        </Trigger>

                        <Trigger Property="Severity" Value="Success">
                            <Setter TargetName="Chrome"     Property="BorderBrush"  Value="#FF107C10"/>
                            <Setter TargetName="Chrome"     Property="Background"   Value="#1A107C10"/>
                            <Setter TargetName="IconBorder" Property="Background"   Value="#FF107C10"/>
                            <Setter TargetName="IconText"   Property="Text"         Value="&#x2713;"/>
                        </Trigger>
                        <Trigger Property="Severity" Value="Warning">
                            <Setter TargetName="Chrome"     Property="BorderBrush"  Value="#FFF0A000"/>
                            <Setter TargetName="Chrome"     Property="Background"   Value="#1AF0A000"/>
                            <Setter TargetName="IconBorder" Property="Background"   Value="#FFF0A000"/>
                            <Setter TargetName="IconText"   Property="Text"         Value="!"/>
                        </Trigger>
                        <Trigger Property="Severity" Value="Error">
                            <Setter TargetName="Chrome"     Property="BorderBrush"  Value="#FFE81123"/>
                            <Setter TargetName="Chrome"     Property="Background"   Value="#1AE81123"/>
                            <Setter TargetName="IconBorder" Property="Background"   Value="#FFE81123"/>
                            <Setter TargetName="IconText"   Property="Text"         Value="&#x2715;"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
