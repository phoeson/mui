<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:FirstFloor.ModernUI.Windows.Controls">

    <!-- ═══════════════════════════════════════════════════════════════════════
         ToggleSwitch
         A sliding on/off toggle with optional header and state labels.

         Usage:
             <mui:ToggleSwitch Header="Auto-dispatch"
                               IsOn="{Binding AutoDispatch, Mode=TwoWay}"
                               OnContent="Enabled"
                               OffContent="Disabled"/>
    ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Internal track / thumb — not keyed for public use -->
    <Style x:Key="ToggleSwitchTrackStyle" TargetType="ToggleButton">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid Width="40" Height="20" SnapsToDevicePixels="True">
                        <!-- Track -->
                        <Border x:Name="Track"
                                CornerRadius="10"
                                Background="{DynamicResource ButtonBackground}"
                                BorderBrush="{DynamicResource ButtonBorder}"
                                BorderThickness="1"/>
                        <!-- Thumb -->
                        <Ellipse x:Name="Thumb"
                                 Width="14" Height="14"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Center"
                                 Margin="3,0,0,0"
                                 Fill="{DynamicResource ButtonText}">
                            <Ellipse.RenderTransform>
                                <TranslateTransform x:Name="ThumbTranslate" X="0"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource ButtonBorderHover}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background"  Value="{DynamicResource Accent}"/>
                            <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            <Setter TargetName="Thumb" Property="Fill"        Value="White"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
                                                         Storyboard.TargetProperty="X"
                                                         To="18" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
                                                         Storyboard.TargetProperty="X"
                                                         To="0" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <!-- Hover while checked — keep accent border -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsChecked"   Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="controls:ToggleSwitch">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Foreground"       Value="{DynamicResource WindowText}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:ToggleSwitch">
                    <StackPanel>
                        <!-- Optional header — collapsed when Header is null -->
                        <ContentPresenter x:Name="HeaderPresenter"
                                          Content="{TemplateBinding Header}"
                                          Margin="0,0,0,6"
                                          TextBlock.Foreground="{DynamicResource WindowText}"
                                          TextBlock.FontWeight="SemiBold"/>

                        <!-- Track + state label row -->
                        <DockPanel VerticalAlignment="Center">
                            <ToggleButton x:Name="PART_Track"
                                          DockPanel.Dock="Left"
                                          Style="{StaticResource ToggleSwitchTrackStyle}"/>

                            <TextBlock x:Name="OffLabel"
                                       Text="{TemplateBinding OffContent}"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"
                                       Foreground="{DynamicResource WindowTextReadOnly}"/>
                            <TextBlock x:Name="OnLabel"
                                       Text="{TemplateBinding OnContent}"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"
                                       Foreground="{DynamicResource WindowText}"
                                       Visibility="Collapsed"/>
                        </DockPanel>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <!-- Hide header when not set -->
                        <DataTrigger Binding="{Binding Header, RelativeSource={RelativeSource TemplatedParent}}"
                                     Value="{x:Null}">
                            <Setter TargetName="HeaderPresenter" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>

                        <!-- Swap state label based on track checked state -->
                        <Trigger SourceName="PART_Track" Property="IsChecked" Value="True">
                            <Setter TargetName="OnLabel"  Property="Visibility" Value="Visible"/>
                            <Setter TargetName="OffLabel" Property="Visibility" Value="Collapsed"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
