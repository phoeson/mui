<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════════
         Card
         A bordered surface for grouping related content.

         Usage:
             <Border Style="{StaticResource Card}">
                 <StackPanel>
                     <TextBlock Text="Title" Style="{StaticResource CardTitle}"/>
                     <TextBlock Text="Supporting text." Style="{StaticResource CardDescription}"/>
                 </StackPanel>
             </Border>

         AccentCard adds a thick accent-coloured left edge to draw attention.
    ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Base card surface -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background"      Value="{DynamicResource ButtonBackground}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource ButtonBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="2"/>
        <Setter Property="Padding"         Value="16"/>
    </Style>

    <!-- Accent card — left edge uses the accent colour to draw attention -->
    <Style x:Key="AccentCard" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="BorderBrush"     Value="{DynamicResource Accent}"/>
        <Setter Property="BorderThickness" Value="3,1,1,1"/>
    </Style>

    <!-- Card title — primary heading inside a card -->
    <Style x:Key="CardTitle" TargetType="TextBlock">
        <Setter Property="Foreground"   Value="{DynamicResource WindowText}"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
        <Setter Property="FontSize"     Value="13"/>
        <Setter Property="Margin"       Value="0,0,0,6"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- Card description — secondary / body text inside a card -->
    <Style x:Key="CardDescription" TargetType="TextBlock">
        <Setter Property="Foreground"   Value="{DynamicResource WindowTextReadOnly}"/>
        <Setter Property="FontSize"     Value="12"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

</ResourceDictionary>
